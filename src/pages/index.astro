---
import Base from '../layouts/Base.astro';
---
<Base title="LiaBakes SG — Home-baked treats with love 🧁">

<style>
  :root {
    --stitch-blue: #3b82c4;
    --stitch-dark: #1e3a5f;
    --stitch-light: #7ec8e3;
    --stitch-pink: #f0a6ca;
    --stitch-cream: #fdf6ec;
    --stitch-lavender: #c8b6e2;
    --frosting-white: #fff5f9;
    --warm-brown: #8b6f47;
    --font-display: 'Fredoka', sans-serif;
    --font-body: 'Quicksand', sans-serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-body);
    background: var(--stitch-cream);
    color: var(--stitch-dark);
    overflow-x: hidden;
  }

  /* ═══ NAV ═══ */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(253, 246, 236, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 2px solid rgba(126, 200, 227, 0.2);
    transition: all 0.3s ease;
  }

  nav.scrolled {
    padding: 0.6rem 2rem;
    box-shadow: 0 4px 20px rgba(30, 58, 95, 0.08);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--stitch-blue);
    text-decoration: none;
    letter-spacing: -0.5px;
  }

  .nav-logo span {
    color: var(--stitch-pink);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--stitch-dark);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    position: relative;
    transition: color 0.3s;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--stitch-pink);
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--stitch-blue);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  /* ═══ HERO ═══ */
  #hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  #three-canvas {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    pointer-events: none;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 700;
    color: var(--stitch-dark);
    line-height: 1.1;
    margin-bottom: 0.5rem;
    text-shadow: 0 2px 20px rgba(253, 246, 236, 0.8);
  }

  .hero-title .accent {
    color: var(--stitch-pink);
    display: inline-block;
    animation: wobble 3s ease-in-out infinite;
  }

  @keyframes wobble {
    0%, 100% { transform: rotate(-2deg); }
    50% { transform: rotate(2deg); }
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    font-weight: 500;
    color: var(--stitch-blue);
    margin-bottom: 2rem;
    text-shadow: 0 1px 10px rgba(253, 246, 236, 0.9);
  }

  .hero-cta {
    pointer-events: all;
    display: inline-block;
    padding: 0.9rem 2.5rem;
    background: var(--stitch-pink);
    color: white;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    border: none;
    border-radius: 50px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(240, 166, 202, 0.4);
  }

  .hero-cta:hover {
    transform: translateY(-2px) scale(1.05);
    box-shadow: 0 8px 25px rgba(240, 166, 202, 0.5);
    background: #e893b8;
  }

  .hero-tap-hint {
    position: absolute;
    bottom: 5.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-size: .75rem;
    font-weight: 600;
    color: var(--stitch-pink);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    opacity: 0;
    animation: fadeInHint 1s ease 2s forwards;
  }

  @keyframes fadeInHint {
    to { opacity: .7; }
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--stitch-blue);
    text-transform: uppercase;
    letter-spacing: 2px;
    animation: bounce 2s ease-in-out infinite;
    opacity: 0.7;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-8px); }
  }

  /* ═══ SECTIONS ═══ */
  section {
    padding: 6rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--stitch-dark);
    text-align: center;
    margin-bottom: 1rem;
  }

  .section-title .pink { color: var(--stitch-pink); }
  .section-title .blue { color: var(--stitch-blue); }

  .section-subtitle {
    text-align: center;
    font-size: 1.1rem;
    color: var(--warm-brown);
    margin-bottom: 3rem;
    font-weight: 500;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ═══ ABOUT ═══ */
  #about {
    background: linear-gradient(180deg, var(--stitch-cream) 0%, var(--frosting-white) 100%);
    position: relative;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-visual {
    position: relative;
    height: 400px;
    border-radius: 24px;
    overflow: hidden;
    background: linear-gradient(135deg, var(--stitch-light), var(--stitch-lavender));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-visual-text {
    font-family: var(--font-display);
    font-size: 5rem;
    text-align: center;
    line-height: 1.2;
  }

  .about-text p {
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1.2rem;
    color: var(--stitch-dark);
  }

  .about-text .highlight {
    background: linear-gradient(180deg, transparent 50%, rgba(240, 166, 202, 0.3) 50%);
    font-weight: 600;
  }

  /* ═══ MENU ═══ */
  #menu {
    background: var(--frosting-white);
  }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .menu-card {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    border: 2px solid transparent;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .menu-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--stitch-blue), var(--stitch-pink), var(--stitch-lavender));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .menu-card:hover {
    transform: translateY(-8px);
    border-color: var(--stitch-light);
    box-shadow: 0 12px 40px rgba(59, 130, 196, 0.12);
  }

  .menu-card:hover::before {
    opacity: 1;
  }

  .menu-emoji {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    display: block;
    transition: transform 0.3s ease;
  }

  .menu-card:hover .menu-emoji {
    transform: scale(1.2) rotate(-5deg);
    animation: jiggle 0.5s ease;
  }

  @keyframes jiggle {
    0%, 100% { transform: scale(1.2) rotate(-5deg); }
    25% { transform: scale(1.2) rotate(5deg); }
    50% { transform: scale(1.2) rotate(-3deg); }
    75% { transform: scale(1.2) rotate(3deg); }
  }

  .menu-card h3 {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--stitch-dark);
    margin-bottom: 0.5rem;
  }

  .menu-card p {
    font-size: 0.95rem;
    color: var(--warm-brown);
    line-height: 1.6;
  }

  .menu-note {
    text-align: center;
    margin-top: 2rem;
    font-size: 0.9rem;
    color: var(--stitch-blue);
    font-weight: 600;
    font-style: italic;
  }

  /* ═══ ORDER ═══ */
  #order {
    text-align: center;
    background: linear-gradient(135deg, var(--stitch-dark) 0%, #2a4f7a 100%);
    color: white;
    border-radius: 0;
    max-width: 100%;
    padding: 6rem 2rem;
  }

  #order .section-title { color: white; }
  #order .section-title .pink { color: var(--stitch-pink); }
  #order .section-subtitle { color: var(--stitch-light); }

  .order-buttons {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .order-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 2rem;
    border-radius: 50px;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .order-btn.instagram {
    background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: white;
    box-shadow: 0 4px 15px rgba(220, 39, 67, 0.3);
  }

  .order-btn.whatsapp {
    background: #25d366;
    color: white;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
  }

  .order-btn:hover {
    transform: translateY(-3px) scale(1.05);
  }

  .order-btn.instagram:hover {
    box-shadow: 0 8px 25px rgba(220, 39, 67, 0.4);
  }

  .order-btn.whatsapp:hover {
    box-shadow: 0 8px 25px rgba(37, 211, 102, 0.4);
  }

  /* ═══ FOOTER ═══ */
  footer {
    text-align: center;
    padding: 2rem;
    background: var(--stitch-dark);
    color: var(--stitch-light);
    font-size: 0.85rem;
  }

  footer a {
    color: var(--stitch-pink);
    text-decoration: none;
  }

  .footer-ohana {
    font-family: var(--font-display);
    font-size: 1rem;
    margin-bottom: 0.5rem;
    color: var(--stitch-lavender);
  }

  /* ═══ MOBILE ═══ */
  @media (max-width: 768px) {
    .nav-links { display: none; }

    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-visual { height: 250px; }

    section { padding: 4rem 1.5rem; }

    .order-buttons { flex-direction: column; align-items: center; }
  }

  /* ═══ FADE-IN ANIMATION ═══ */
  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ═══ FLOATING DECORATIONS ═══ */
  .float-deco {
    position: fixed;
    pointer-events: none;
    z-index: 0;
    opacity: 0.06;
    font-size: 4rem;
    animation: floatDeco 20s ease-in-out infinite;
  }

  .float-deco:nth-child(1) { top: 20%; left: 5%; animation-delay: 0s; }
  .float-deco:nth-child(2) { top: 60%; right: 5%; animation-delay: -7s; }
  .float-deco:nth-child(3) { top: 80%; left: 15%; animation-delay: -14s; }

  @keyframes floatDeco {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    33% { transform: translateY(-20px) rotate(5deg); }
    66% { transform: translateY(10px) rotate(-3deg); }
  }
</style>

<!-- Floating decorations -->
<div class="float-deco">🧁</div>
<div class="float-deco">🍪</div>
<div class="float-deco">🎂</div>

<!-- NAV -->
<nav id="navbar">
  <a href="#hero" class="nav-logo">Lia<span>Bakes</span></a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#menu">Treats</a></li>
    <li><a href="#order">Order</a></li>
  </ul>
</nav>

<!-- HERO with Three.js -->
<section id="hero">
  <canvas id="three-canvas"></canvas>
  <div class="hero-content">
    <h1 class="hero-title">Lia<span class="accent">Bakes</span></h1>
    <p class="hero-subtitle">Home-baked treats made with love in Singapore</p>
    <a href="#order" class="hero-cta">Order Now</a>
  </div>
  <div class="hero-tap-hint">tap the cupcakes!</div>
  <div class="scroll-hint">scroll to explore</div>
</section>

<!-- ABOUT -->
<section id="about">
  <h2 class="section-title fade-up">Meet <span class="pink">Lia</span></h2>
  <p class="section-subtitle fade-up">The baker behind the treats</p>
  <div class="about-grid">
    <div class="about-visual fade-up">
      <div class="about-visual-text">👩‍🍳🧁✨</div>
    </div>
    <div class="about-text fade-up">
      <p>
        Hi! I'm <span class="highlight">Lia</span>, a home baker based in sunny Singapore.
        What started as a hobby baking for family and friends has grown into something
        I absolutely love sharing with everyone.
      </p>
      <p>
        Every treat is baked fresh with <span class="highlight">quality ingredients</span>
        and a whole lot of heart. From classic cupcakes to custom celebration cakes,
        I pour my passion into every creation.
      </p>
      <p>
        Whether it's a birthday, a gathering, or just a Tuesday that needs a little sweetness —
        I've got you covered! 💙
      </p>
    </div>
  </div>
</section>

<!-- MENU -->
<section id="menu">
  <h2 class="section-title fade-up">The <span class="blue">Treats</span></h2>
  <p class="section-subtitle fade-up">Baked fresh, made to order</p>
  <div class="menu-grid">
    <div class="menu-card fade-up">
      <span class="menu-emoji">🧁</span>
      <h3>Cupcakes</h3>
      <p>Classic flavours with beautiful buttercream swirls. Perfect for parties and gifting.</p>
    </div>
    <div class="menu-card fade-up">
      <span class="menu-emoji">🎂</span>
      <h3>Custom Cakes</h3>
      <p>Celebration cakes tailored to your theme. Tell me your vision and I'll bring it to life!</p>
    </div>
    <div class="menu-card fade-up">
      <span class="menu-emoji">🍪</span>
      <h3>Cookies</h3>
      <p>Chunky, chewy cookies in flavours like chocolate chip, matcha, and red velvet.</p>
    </div>
    <div class="menu-card fade-up">
      <span class="menu-emoji">🍰</span>
      <h3>Brownies & Bars</h3>
      <p>Fudgy brownies and dessert bars — rich, indulgent, and impossibly good.</p>
    </div>
  </div>
  <p class="menu-note fade-up">
    Menu changes seasonally! Check Instagram for the latest bakes ✨
  </p>
</section>

<!-- ORDER -->
<section id="order">
  <h2 class="section-title fade-up">Ready to <span class="pink">Order</span>?</h2>
  <p class="section-subtitle fade-up">
    DM me on Instagram or drop a WhatsApp message. I'd love to bake for you!
  </p>
  <div class="order-buttons fade-up">
