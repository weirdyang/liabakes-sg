      WhatsApp
    </a>
  </div>
</section>

<footer>
  <p class="footer-tagline">Ohana means family — and cake!</p>
  <p>&copy; 2025 <a href="https://www.instagram.com/liabakes_sg/" target="_blank" rel="noopener">LiaBakes SG</a>. Baked with love in Singapore.</p>
</footer>

<!-- Three.js scene — Astro bundles this automatically -->
<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('heroCanvas') as HTMLCanvasElement;
  const loaderEl = document.getElementById('heroLoader') as HTMLDivElement;
  const nav = document.getElementById('navbar')!;
  const burger = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobileMenu')!;
  const heroSection = document.querySelector('.hero') as HTMLElement;

  // ═══ MOBILE NAV ═══
  burger.addEventListener('click', () => {
    const open = burger.classList.toggle('open');
    mobileMenu.classList.toggle('open', open);
    burger.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  });
  mobileMenu.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      burger.classList.remove('open');
      mobileMenu.classList.remove('open');
      burger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });

  // ═══ NAV SCROLL ═══
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  // ═══ SCROLL REVEAL ═══
  const revealObs = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach((el) => revealObs.observe(el));

  // ═══ THREE.JS — scoped to hero canvas ═══
  function heroSize() {
    return { w: heroSection.clientWidth, h: heroSection.clientHeight };
  }
  const sz = heroSize();

  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(sz.w, sz.h);
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.3;

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(35, sz.w / sz.h, 0.1, 100);
  camera.position.set(0, 1.2, 5.5);
  camera.lookAt(0, 0.6, 0);

  // Lights — clean 3-point
  scene.add(new THREE.HemisphereLight(0xffffff, 0xc8b6e2, 1.0));
  const keyLight = new THREE.DirectionalLight(0xffffff, 1.4);
  keyLight.position.set(4, 8, 6);
  scene.add(keyLight);
  const fillLight = new THREE.DirectionalLight(0xfdf6ec, 0.6);
  fillLight.position.set(-4, 4, -3);
  scene.add(fillLight);
  const rimLight = new THREE.PointLight(0xf0a6ca, 0.5, 15);
  rimLight.position.set(2, 3, 4);
  scene.add(rimLight);

  // ── Sparkle particles ──
  const pCount = 50;
  const pGeo = new THREE.BufferGeometry();
  const pPos = new Float32Array(pCount * 3);
  for (let i = 0; i < pCount; i++) {
    pPos[i * 3] = (Math.random() - 0.5) * 12;
    pPos[i * 3 + 1] = Math.random() * 7 - 2;
    pPos[i * 3 + 2] = (Math.random() - 0.5) * 12;
  }
  pGeo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
  const pMat = new THREE.PointsMaterial({
    color: 0xf0a6ca, size: 0.04,
    transparent: true, opacity: 0.35,
    blending: THREE.AdditiveBlending,
  });
  scene.add(new THREE.Points(pGeo, pMat));

  // ── Procedural cupcake ──
  const wrapper = new THREE.Group();
  scene.add(wrapper);

  function buildCupcake(): THREE.Group {
    const g = new THREE.Group();

    // Paper liner
    const linerGeo = new THREE.CylinderGeometry(0.55, 0.38, 0.7, 32);
    const linerMat = new THREE.MeshStandardMaterial({ color: 0xf0a6ca, roughness: 0.5 });
    const liner = new THREE.Mesh(linerGeo, linerMat);
    liner.position.y = 0.35;
    g.add(liner);

    // Liner ridges
    for (let r = 0; r < 6; r++) {
      const ringGeo = new THREE.TorusGeometry(0.38 + r * 0.028, 0.012, 4, 32);
      const ringMat = new THREE.MeshStandardMaterial({ color: 0xe48bb5, roughness: 0.4 });
      const ring = new THREE.Mesh(ringGeo, ringMat);
      ring.rotation.x = Math.PI / 2;
      ring.position.y = 0.08 + r * 0.1;
      g.add(ring);
    }

    // Cake body
    const cakeGeo = new THREE.CylinderGeometry(0.5, 0.48, 0.3, 32);
    const cakeMat = new THREE.MeshStandardMaterial({ color: 0xf5d5a0, roughness: 0.7 });
    const cake = new THREE.Mesh(cakeGeo, cakeMat);
    cake.position.y = 0.72;
    g.add(cake);

    // Frosting layers
    const frostMat = new THREE.MeshStandardMaterial({ color: 0xfce4ec, roughness: 0.25, metalness: 0.02 });

    const f1 = new THREE.Mesh(new THREE.TorusGeometry(0.32, 0.16, 12, 24), frostMat);
    f1.rotation.x = Math.PI / 2;
    f1.position.y = 0.95;
    g.add(f1);

    const f2 = new THREE.Mesh(new THREE.SphereGeometry(0.3, 16, 12), frostMat);
    f2.position.y = 1.15;
    f2.scale.set(1, 0.65, 1);
    g.add(f2);

    const f3 = new THREE.Mesh(new THREE.SphereGeometry(0.18, 12, 10), frostMat);
    f3.position.y = 1.35;
    f3.scale.set(1, 0.7, 1);
    g.add(f3);

    const f4 = new THREE.Mesh(new THREE.ConeGeometry(0.1, 0.14, 10), frostMat);
    f4.position.y = 1.5;
    g.add(f4);

    // Cherry
    const cherryMat = new THREE.MeshStandardMaterial({ color: 0xdc2743, roughness: 0.2, metalness: 0.1 });
    const cherry = new THREE.Mesh(new THREE.SphereGeometry(0.08, 12, 8), cherryMat);
    cherry.position.y = 1.6;
    g.add(cherry);

    // Stem
    const stemGeo = new THREE.CylinderGeometry(0.01, 0.01, 0.12, 4);
    const stemMat = new THREE.MeshStandardMaterial({ color: 0x4a7c3f });
    const stem = new THREE.Mesh(stemGeo, stemMat);
    stem.position.y = 1.7;
    stem.rotation.z = 0.3;
    g.add(stem);

    // Sprinkles
    const sprinkleColors = [0xf0a6ca, 0x7ec8e3, 0xc8b6e2, 0xffd700, 0x25d366, 0xff6b6b, 0x4ecdc4];
    for (let s = 0; s < 30; s++) {
      const sGeo = new THREE.CylinderGeometry(0.015, 0.015, 0.06, 4);
      const sMat = new THREE.MeshStandardMaterial({ color: sprinkleColors[s % sprinkleColors.length] });
      const sprinkle = new THREE.Mesh(sGeo, sMat);
      const angle = Math.random() * Math.PI * 2;
      const radius = 0.15 + Math.random() * 0.22;
      sprinkle.position.set(Math.cos(angle) * radius, 0.95 + Math.random() * 0.4, Math.sin(angle) * radius);
      sprinkle.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, Math.random() * Math.PI);
      g.add(sprinkle);
    }

    g.position.y = -0.5;
    return g;
  }

  wrapper.add(buildCupcake());
  loaderEl.classList.add('done');

  // ── Drag to spin ──
  const drag = { active: false, prevX: 0, rotY: 0, targetRotY: 0, auto: 0.004 };

  canvas.addEventListener('pointerdown', (e) => {
    drag.active = true;
    drag.prevX = e.clientX;
    canvas.setPointerCapture(e.pointerId);
  });
  canvas.addEventListener('pointermove', (e) => {
    if (!drag.active) return;
    drag.targetRotY += (e.clientX - drag.prevX) * 0.008;
    drag.prevX = e.clientX;
  });
  canvas.addEventListener('pointerup', () => { drag.active = false; });
  canvas.addEventListener('pointercancel', () => { drag.active = false; });

  // ── Resize ──
  window.addEventListener('resize', () => {
    const s = heroSize();
    camera.aspect = s.w / s.h;
    camera.updateProjectionMatrix();
    renderer.setSize(s.w, s.h);
  });

  // ── Animate (pauses off-screen) ──
  const clock = new THREE.Clock();
  let raf: number | null = null;

  function animate() {
    raf = requestAnimationFrame(animate);
    const t = clock.getElapsedTime();

    if (!drag.active) drag.targetRotY += drag.auto;
    drag.rotY += (drag.targetRotY - drag.rotY) * 0.08;
    wrapper.rotation.y = drag.rotY;
    wrapper.position.y = Math.sin(t * 1.2) * 0.04;

    const pos = pGeo.attributes.position as THREE.BufferAttribute;
    for (let i = 0; i < pCount; i++) {
      let y = pos.getY(i);
      y += 0.004;
      if (y > 5) y = -2;
      pos.setY(i, y);
    }
    pos.needsUpdate = true;
    pMat.opacity = 0.2 + Math.sin(t * 2) * 0.1;

    renderer.render(scene, camera);
  }

  const heroObs = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      if (!raf) animate();
    } else {
      if (raf) { cancelAnimationFrame(raf); raf = null; }
    }
  }, { threshold: 0.05 });
  heroObs.observe(heroSection);
</script>

</Base>