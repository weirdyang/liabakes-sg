      WhatsApp
    </a>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <p class="footer-ohana">Ohana means family — and cake! 💙</p>
  <p>&copy; 2025 <a href="https://www.instagram.com/liabakes_sg/" target="_blank" rel="noopener">LiaBakes SG</a>. Baked with love in Singapore.</p>
</footer>

<!-- Three.js Scene -->
<script>
  import * as THREE from 'three';

  // ═══ THREE.JS BAKERY SCENE ═══
  const canvas = document.getElementById('three-canvas') as HTMLCanvasElement;
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 100);
  camera.position.set(0, 2, 8);
  camera.lookAt(0, 0, 0);

  // Lights
  const ambientLight = new THREE.AmbientLight(0xfdf6ec, 0.8);
  scene.add(ambientLight);

  const mainLight = new THREE.DirectionalLight(0xfff5f9, 1.2);
  mainLight.position.set(5, 8, 5);
  scene.add(mainLight);

  const fillLight = new THREE.DirectionalLight(0x7ec8e3, 0.4);
  fillLight.position.set(-5, 3, -3);
  scene.add(fillLight);

  const pinkLight = new THREE.PointLight(0xf0a6ca, 0.6, 20);
  pinkLight.position.set(3, 2, 4);
  scene.add(pinkLight);

  // ═══ Materials ═══
  const cakeMat = new THREE.MeshStandardMaterial({ color: 0xdeb887, roughness: 0.6, metalness: 0.05 });
  const frostingPinkMat = new THREE.MeshStandardMaterial({ color: 0xf0a6ca, roughness: 0.3, metalness: 0.05 });
  const frostingBlueMat = new THREE.MeshStandardMaterial({ color: 0x7ec8e3, roughness: 0.3, metalness: 0.05 });
  const frostingLavMat = new THREE.MeshStandardMaterial({ color: 0xc8b6e2, roughness: 0.3, metalness: 0.05 });
  const linerMat = new THREE.MeshStandardMaterial({ color: 0xffffff, roughness: 0.5, metalness: 0.0 });
  const cookieMat = new THREE.MeshStandardMaterial({ color: 0xd4a056, roughness: 0.8, metalness: 0.0 });
  const chipMat = new THREE.MeshStandardMaterial({ color: 0x4a3520, roughness: 0.7, metalness: 0.0 });
  const sprinkleMats = [
    new THREE.MeshStandardMaterial({ color: 0xf0a6ca, roughness: 0.3 }),
    new THREE.MeshStandardMaterial({ color: 0x7ec8e3, roughness: 0.3 }),
    new THREE.MeshStandardMaterial({ color: 0xc8b6e2, roughness: 0.3 }),
    new THREE.MeshStandardMaterial({ color: 0xffd700, roughness: 0.3 }),
    new THREE.MeshStandardMaterial({ color: 0xff6b6b, roughness: 0.3 }),
  ];

  // ═══ Create Cupcake function ═══
  function createCupcake(frostingMat: THREE.Material): THREE.Group {
    const group = new THREE.Group();

    // Cupcake liner (truncated cone)
    const linerGeo = new THREE.CylinderGeometry(0.55, 0.35, 0.7, 16);
    const liner = new THREE.Mesh(linerGeo, linerMat);
    liner.position.y = 0.35;
    group.add(liner);

    // Cake body
    const cakeGeo = new THREE.CylinderGeometry(0.5, 0.48, 0.6, 16);
    const cake = new THREE.Mesh(cakeGeo, cakeMat);
    cake.position.y = 0.4;
    group.add(cake);

    // Frosting swirl (stacked spheres)
    const swirl: THREE.Mesh[] = [];
    for (let i = 0; i < 8; i++) {
      const angle = (i / 8) * Math.PI * 2.5;
      const radius = 0.25 - i * 0.02;
      const y = 0.75 + i * 0.08;
      const size = 0.22 - i * 0.015;

      const geo = new THREE.SphereGeometry(size, 12, 12);
      const mesh = new THREE.Mesh(geo, frostingMat);
      mesh.position.set(
        Math.cos(angle) * radius,
        y,
        Math.sin(angle) * radius
      );
      group.add(mesh);
      swirl.push(mesh);
    }

    // Top sphere
    const topGeo = new THREE.SphereGeometry(0.12, 12, 12);
    const top = new THREE.Mesh(topGeo, frostingMat);
    top.position.y = 1.4;
    group.add(top);

    // Sprinkles
    const sprinkleGeo = new THREE.CylinderGeometry(0.015, 0.015, 0.08, 6);
    for (let i = 0; i < 12; i++) {
      const mat = sprinkleMats[Math.floor(Math.random() * sprinkleMats.length)];
      const sprinkle = new THREE.Mesh(sprinkleGeo, mat);
      const a = Math.random() * Math.PI * 2;
      const r = 0.15 + Math.random() * 0.2;
      const h = 0.85 + Math.random() * 0.4;
      sprinkle.position.set(Math.cos(a) * r, h, Math.sin(a) * r);
      sprinkle.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, Math.random() * Math.PI);
      group.add(sprinkle);
    }

    return group;
  }

  // ═══ Create Cookie function ═══
  function createCookie(): THREE.Group {
    const group = new THREE.Group();

    const geo = new THREE.CylinderGeometry(0.5, 0.5, 0.12, 24);
    const cookie = new THREE.Mesh(geo, cookieMat);
    group.add(cookie);

    // Chocolate chips
    const chipGeo = new THREE.SphereGeometry(0.06, 8, 8);
    for (let i = 0; i < 7; i++) {
      const chip = new THREE.Mesh(chipGeo, chipMat);
      const a = Math.random() * Math.PI * 2;
      const r = Math.random() * 0.35;
      chip.position.set(Math.cos(a) * r, 0.07, Math.sin(a) * r);
      chip.scale.y = 0.6;
      group.add(chip);
    }

    return group;
  }

  // ═══ Create Donut function ═══
  function createDonut(): THREE.Group {
    const group = new THREE.Group();

    const torusGeo = new THREE.TorusGeometry(0.35, 0.18, 16, 32);
    const donut = new THREE.Mesh(torusGeo, cakeMat);
    group.add(donut);

    // Glaze (slightly larger torus on top)
    const glazeGeo = new THREE.TorusGeometry(0.35, 0.19, 16, 32, Math.PI);
    const glaze = new THREE.Mesh(glazeGeo, frostingPinkMat);
    glaze.rotation.x = Math.PI;
    glaze.position.y = 0.02;
    group.add(glaze);

    // Sprinkles on donut
    const sprinkleGeo = new THREE.CylinderGeometry(0.012, 0.012, 0.06, 6);
    for (let i = 0; i < 15; i++) {
      const mat = sprinkleMats[Math.floor(Math.random() * sprinkleMats.length)];
      const sprinkle = new THREE.Mesh(sprinkleGeo, mat);
      const angle = Math.random() * Math.PI * 2;
      const r = 0.3 + Math.random() * 0.1;
      sprinkle.position.set(
        Math.cos(angle) * r,
        0.15 + Math.random() * 0.05,
        Math.sin(angle) * r
      );
      sprinkle.rotation.set(Math.random(), Math.random(), Math.random());
      group.add(sprinkle);
    }

    return group;
  }

  // ═══ Place items ═══
  interface FloatingItem {
    mesh: THREE.Group;
    baseY: number;
    speed: number;
    rotSpeed: number;
    phase: number;
  }

  const items: FloatingItem[] = [];

  // Main cupcake (center)
  const mainCupcake = createCupcake(frostingPinkMat);
  mainCupcake.position.set(0, -0.3, 0);
  mainCupcake.scale.setScalar(1.4);
  scene.add(mainCupcake);
  items.push({ mesh: mainCupcake, baseY: -0.3, speed: 0.6, rotSpeed: 0.15, phase: 0 });

  // Left cupcake
  const leftCupcake = createCupcake(frostingBlueMat);
  leftCupcake.position.set(-3, 0.5, -1);
  leftCupcake.scale.setScalar(0.9);
  leftCupcake.rotation.y = 0.5;
  scene.add(leftCupcake);
  items.push({ mesh: leftCupcake, baseY: 0.5, speed: 0.8, rotSpeed: 0.2, phase: 1.5 });

  // Right cupcake
  const rightCupcake = createCupcake(frostingLavMat);
  rightCupcake.position.set(3.2, 0.2, -0.5);
  rightCupcake.scale.setScalar(0.85);
  rightCupcake.rotation.y = -0.3;
  scene.add(rightCupcake);
  items.push({ mesh: rightCupcake, baseY: 0.2, speed: 0.7, rotSpeed: -0.18, phase: 3 });

  // Cookie
  const cookie = createCookie();
  cookie.position.set(-2, -1.2, 1);
  cookie.scale.setScalar(1.1);
  cookie.rotation.x = 0.2;
  scene.add(cookie);
  items.push({ mesh: cookie, baseY: -1.2, speed: 0.5, rotSpeed: 0.3, phase: 2 });

  // Donut
  const donut = createDonut();
  donut.position.set(2.5, -1, 1.5);
  donut.scale.setScalar(1);
  scene.add(donut);
  items.push({ mesh: donut, baseY: -1, speed: 0.65, rotSpeed: -0.25, phase: 4 });

  // Extra cookie top-right
  const cookie2 = createCookie();
  cookie2.position.set(1.8, 1.8, -2);
  cookie2.scale.setScalar(0.7);
  cookie2.rotation.x = -0.5;
  cookie2.rotation.z = 0.3;
  scene.add(cookie2);
  items.push({ mesh: cookie2, baseY: 1.8, speed: 0.55, rotSpeed: 0.22, phase: 5 });

  // ═══ Particle stars ═══
  const starCount = 60;
  const starGeo = new THREE.BufferGeometry();
  const starPositions = new Float32Array(starCount * 3);
  for (let i = 0; i < starCount; i++) {
    starPositions[i * 3] = (Math.random() - 0.5) * 16;
    starPositions[i * 3 + 1] = (Math.random() - 0.5) * 10;
    starPositions[i * 3 + 2] = (Math.random() - 0.5) * 10 - 2;
  }
  starGeo.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
  const starMat = new THREE.PointsMaterial({
    color: 0xf0a6ca,
    size: 0.06,
    transparent: true,
    opacity: 0.6,
  });
  const stars = new THREE.Points(starGeo, starMat);
  scene.add(stars);

  // ═══ Mouse interaction ═══
  const mouse = { x: 0, y: 0 };

  window.addEventListener('mousemove', (e) => {
    mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
    mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
  });

  // Touch support
  window.addEventListener('touchmove', (e) => {
    if (e.touches.length > 0) {
      mouse.x = (e.touches[0].clientX / window.innerWidth) * 2 - 1;
      mouse.y = -(e.touches[0].clientY / window.innerHeight) * 2 + 1;
    }
  });

  // ═══ Click interaction — raycast to spin whichever item is tapped ═══
  const raycaster = new THREE.Raycaster();
  const spinTargets = new Map<THREE.Group, number>();

  function handleTap(clientX: number, clientY: number) {
    const rect = canvas.getBoundingClientRect();
    const mx = ((clientX - rect.left) / rect.width) * 2 - 1;
    const my = -((clientY - rect.top) / rect.height) * 2 + 1;
    raycaster.setFromCamera({ x: mx, y: my }, camera);
    for (const item of items) {
      const hits = raycaster.intersectObjects(item.mesh.children, true);
      if (hits.length > 0) {
        const current = spinTargets.get(item.mesh) || 0;
        spinTargets.set(item.mesh, current + 10);
        break;
      }
    }
  }

  canvas.addEventListener('click', (e) => handleTap(e.clientX, e.clientY));
  canvas.addEventListener('touchstart', (e) => {
    if (e.touches.length > 0) handleTap(e.touches[0].clientX, e.touches[0].clientY);
  });

  // ═══ Resize ═══
  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });

  // ═══ Nav scroll effect ═══
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });

  // ═══ Intersection Observer for fade-up ═══
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );

  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));

  // ═══ Animation loop ═══
  const clock = new THREE.Clock();

  function animate() {
    requestAnimationFrame(animate);
    const t = clock.getElapsedTime();

    // Float items
    items.forEach((item) => {
      item.mesh.position.y = item.baseY + Math.sin(t * item.speed + item.phase) * 0.2;
      item.mesh.rotation.y += item.rotSpeed * 0.005;
    });

    // Per-item spin from clicks
    spinTargets.forEach((vel, mesh) => {
      if (vel > 0.01) {
        mesh.rotation.y += vel * 0.016;
        spinTargets.set(mesh, vel * 0.95);
      } else {
        spinTargets.delete(mesh);
      }
    });

    // Mouse parallax
    camera.position.x += (mouse.x * 1.5 - camera.position.x) * 0.02;
    camera.position.y += (mouse.y * 0.8 + 2 - camera.position.y) * 0.02;
    camera.lookAt(0, 0.3, 0);

    // Stars twinkle
    starMat.opacity = 0.4 + Math.sin(t * 2) * 0.2;

    renderer.render(scene, camera);
  }

  animate();
</script>

</Base>
