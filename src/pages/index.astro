---
import Base from '../layouts/Base.astro';
---
<Base title="LiaBakes SG — Home-baked treats with love 🧁">

<style>
  :root {
    --sb: #3b82c4; --sd: #1e3a5f; --sl: #7ec8e3; --sp: #f0a6ca;
    --sc: #fdf6ec; --sv: #c8b6e2; --fw: #fff5f9; --wb: #8b6f47;
    --fd: 'Fredoka', sans-serif; --fb: 'Quicksand', sans-serif;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--fb); background: var(--sc); color: var(--sd); overflow-x: hidden; }

  /* NAV */
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; background: rgba(253,246,236,.85); backdrop-filter: blur(12px); border-bottom: 2px solid rgba(126,200,227,.15); transition: all .3s; }
  nav.scrolled { padding: .6rem 2rem; box-shadow: 0 4px 20px rgba(30,58,95,.08); }
  .nav-logo { font-family: var(--fd); font-size: 1.6rem; font-weight: 700; color: var(--sb); text-decoration: none; }
  .nav-logo span { color: var(--sp); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { font-family: var(--fb); font-weight: 600; font-size: .85rem; color: var(--sd); text-decoration: none; text-transform: uppercase; letter-spacing: 1px; transition: color .3s; }
  .nav-links a:hover { color: var(--sb); }

  /* CANVAS — fixed fullscreen background */
  #hero-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: auto; }

  /* HERO */
  #hero { position: relative; height: 100vh; min-height: 650px; display: flex; align-items: center; justify-content: center; overflow: hidden; z-index: 1; }
  .hero-overlay { position: relative; z-index: 2; text-align: center; pointer-events: none; }
  .hero-title { font-family: var(--fd); font-size: clamp(3.5rem,9vw,7rem); font-weight: 700; color: var(--sd); line-height: 1; margin-bottom: .4rem; text-shadow: 0 4px 30px rgba(253,246,236,.95); }
  .hero-title .accent { color: var(--sp); }
  .hero-subtitle { font-family: var(--fb); font-size: clamp(1rem,2.5vw,1.3rem); font-weight: 500; color: var(--wb); margin-bottom: 2rem; text-shadow: 0 2px 10px rgba(253,246,236,.95); }
  .hero-cta { pointer-events: all; display: inline-block; padding: .9rem 2.5rem; background: var(--sp); color: #fff; font-family: var(--fd); font-size: 1.1rem; font-weight: 600; border: none; border-radius: 50px; text-decoration: none; cursor: pointer; transition: all .3s; box-shadow: 0 4px 15px rgba(240,166,202,.4); }
  .hero-cta:hover { transform: translateY(-2px) scale(1.05); box-shadow: 0 8px 25px rgba(240,166,202,.5); background: #e893b8; }
  .hero-drag-hint { position: absolute; bottom: 5rem; left: 50%; transform: translateX(-50%); z-index: 2; font-size: .7rem; font-weight: 600; color: var(--sp); text-transform: uppercase; letter-spacing: 1.5px; opacity: 0; animation: fadeHint 1s ease 2.5s forwards; }
  @keyframes fadeHint { to { opacity: .6; } }
  .scroll-hint { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); z-index: 2; font-size: .75rem; font-weight: 600; color: var(--wb); text-transform: uppercase; letter-spacing: 2px; animation: bounce 2s ease-in-out infinite; opacity: .6; }
  @keyframes bounce { 0%,100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(-8px); } }

  /* Loading */
  #loading { position: fixed; inset: 0; z-index: 50; display: flex; align-items: center; justify-content: center; background: rgba(253,246,236,.9); font-family: var(--fd); font-size: 1.2rem; color: var(--sp); transition: opacity .5s; }
  #loading.hidden { opacity: 0; pointer-events: none; }

  /* SECTIONS */
  section { padding: 6rem 2rem; max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; pointer-events: none; }
  section a, section button, .menu-card { pointer-events: auto; }
  .section-title { font-family: var(--fd); font-size: clamp(2rem,5vw,3rem); font-weight: 700; color: var(--sd); text-align: center; margin-bottom: 1rem; }
  .section-title .pink { color: var(--sp); }
  .section-title .blue { color: var(--sb); }
  .section-subtitle { text-align: center; font-size: 1.1rem; color: var(--wb); margin-bottom: 3rem; font-weight: 500; max-width: 600px; margin-left: auto; margin-right: auto; }

  /* ABOUT */
  #about { background: rgba(253,246,236,.92); backdrop-filter: blur(8px); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .about-visual { height: 400px; border-radius: 24px; overflow: hidden; background: linear-gradient(135deg, var(--sl), var(--sv)); display: flex; align-items: center; justify-content: center; }
  .about-visual-text { font-size: 5rem; text-align: center; }
  .about-text p { font-size: 1.05rem; line-height: 1.8; margin-bottom: 1.2rem; }
  .about-text .highlight { background: linear-gradient(180deg, transparent 50%, rgba(240,166,202,.3) 50%); font-weight: 600; }

  /* MENU */
  #menu { background: rgba(255,245,249,.92); backdrop-filter: blur(8px); }
  .menu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
  .menu-card { background: #fff; border-radius: 20px; padding: 2rem; text-align: center; transition: all .4s cubic-bezier(.175,.885,.32,1.275); border: 2px solid transparent; position: relative; overflow: hidden; }
  .menu-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, var(--sb), var(--sp), var(--sv)); opacity: 0; transition: opacity .3s; }
  .menu-card:hover { transform: translateY(-8px); border-color: var(--sl); box-shadow: 0 12px 40px rgba(59,130,196,.12); }
  .menu-card:hover::before { opacity: 1; }
  .menu-emoji { font-size: 3.5rem; margin-bottom: 1rem; display: block; transition: transform .3s; }
  .menu-card:hover .menu-emoji { transform: scale(1.2) rotate(-5deg); }
  .menu-card h3 { font-family: var(--fd); font-size: 1.3rem; color: var(--sd); margin-bottom: .5rem; }
  .menu-card p { font-size: .95rem; color: var(--wb); line-height: 1.6; }
  .menu-note { text-align: center; margin-top: 2rem; font-size: .9rem; color: var(--sb); font-weight: 600; font-style: italic; }

  /* ORDER */
  #order { text-align: center; background: rgba(30,58,95,.92); backdrop-filter: blur(8px); color: #fff; max-width: 100%; padding: 6rem 2rem; position: relative; z-index: 1; pointer-events: none; }
  #order .section-title { color: #fff; }
  #order .section-title .pink { color: var(--sp); }
  #order .section-subtitle { color: var(--sl); }
  .order-buttons { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; margin-top: 2rem; }
  .order-btn { display: inline-flex; align-items: center; gap: .6rem; padding: 1rem 2rem; border-radius: 50px; font-family: var(--fd); font-size: 1.1rem; font-weight: 600; text-decoration: none; transition: all .3s; }
  .order-btn.ig { background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); color: #fff; box-shadow: 0 4px 15px rgba(220,39,67,.3); }
  .order-btn.wa { background: #25d366; color: #fff; box-shadow: 0 4px 15px rgba(37,211,102,.3); }
  .order-btn:hover { transform: translateY(-3px) scale(1.05); }

  footer { text-align: center; padding: 2rem; background: rgba(30,58,95,.95); color: var(--sl); font-size: .85rem; position: relative; z-index: 1; pointer-events: none; }
  footer a { color: var(--sp); text-decoration: none; pointer-events: auto; }
  .footer-ohana { font-family: var(--fd); font-size: 1rem; margin-bottom: .5rem; color: var(--sv); }

  .fade-up { opacity: 0; transform: translateY(30px); transition: opacity .8s, transform .8s; }
  .fade-up.visible { opacity: 1; transform: translateY(0); }

  /* Attribution */
  .model-credit { position: absolute; bottom: 7.5rem; left: 50%; transform: translateX(-50%); z-index: 2; font-size: .6rem; color: var(--wb); opacity: .5; text-align: center; }
  .model-credit a { color: var(--sb); text-decoration: none; }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
    .about-visual { height: 250px; }
    section { padding: 4rem 1.5rem; }
    .order-buttons { flex-direction: column; align-items: center; }
  }
</style>

<!-- NAV -->
<nav id="navbar">
  <a href="#hero" class="nav-logo">Lia<span>Bakes</span></a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#menu">Treats</a></li>
    <li><a href="#order">Order</a></li>
  </ul>
</nav>

<!-- FIXED 3D CANVAS BACKGROUND -->
<canvas id="hero-canvas"></canvas>
<div id="loading">Loading treats...</div>

<!-- HERO -->
<section id="hero">
  <div class="hero-overlay">
    <h1 class="hero-title">Lia<span class="accent">Bakes</span></h1>
    <p class="hero-subtitle">Home-baked treats made with love in Singapore</p>
    <a href="#order" class="hero-cta">Order Now</a>
  </div>
  <div class="hero-drag-hint">drag to spin</div>
  <div class="model-credit">
    3D model by <a href="https://sketchfab.com/iclartworks" target="_blank" rel="noopener">iclartworks</a> (CC-BY)
  </div>
  <div class="scroll-hint">scroll to explore</div>
</section>

<!-- ABOUT -->
<section id="about">
  <h2 class="section-title fade-up">Meet <span class="pink">Lia</span></h2>
  <p class="section-subtitle fade-up">The baker behind the treats</p>
  <div class="about-grid">
    <div class="about-visual fade-up"><div class="about-visual-text">👩‍🍳🧁✨</div></div>
    <div class="about-text fade-up">
      <p>Hi! I'm <span class="highlight">Lia</span>, a home baker based in sunny Singapore. What started as a hobby baking for family and friends has grown into something I absolutely love sharing with everyone.</p>
      <p>Every treat is baked fresh with <span class="highlight">quality ingredients</span> and a whole lot of heart. From classic cupcakes to custom celebration cakes, I pour my passion into every creation.</p>
      <p>Whether it's a birthday, a gathering, or just a Tuesday that needs a little sweetness — I've got you covered!</p>
    </div>
  </div>
</section>

<!-- MENU -->
<section id="menu">
  <h2 class="section-title fade-up">The <span class="blue">Treats</span></h2>
  <p class="section-subtitle fade-up">Baked fresh, made to order</p>
  <div class="menu-grid">
    <div class="menu-card fade-up"><span class="menu-emoji">🧁</span><h3>Cupcakes</h3><p>Classic flavours with beautiful buttercream swirls. Perfect for parties and gifting.</p></div>
    <div class="menu-card fade-up"><span class="menu-emoji">🎂</span><h3>Custom Cakes</h3><p>Celebration cakes tailored to your theme. Tell me your vision and I'll bring it to life!</p></div>
    <div class="menu-card fade-up"><span class="menu-emoji">🍪</span><h3>Cookies</h3><p>Chunky, chewy cookies in flavours like chocolate chip, matcha, and red velvet.</p></div>
    <div class="menu-card fade-up"><span class="menu-emoji">🍰</span><h3>Brownies & Bars</h3><p>Fudgy brownies and dessert bars — rich, indulgent, and impossibly good.</p></div>
  </div>
  <p class="menu-note fade-up">Menu changes seasonally! Check Instagram for the latest bakes</p>
</section>

<!-- ORDER -->
<section id="order">
  <h2 class="section-title fade-up">Ready to <span class="pink">Order</span>?</h2>
  <p class="section-subtitle fade-up">DM me on Instagram or drop a WhatsApp message. I'd love to bake for you!</p>
  <div class="order-buttons fade-up">
    <a href="https://www.instagram.com/liabakes_sg/" target="_blank" rel="noopener" class="order-btn ig">@liabakes_sg</a>
    <a href="https://wa.me/" target="_blank" rel="noopener" class="order-btn wa">WhatsApp</a>
  </div>
</section>

<footer>
  <p class="footer-ohana">Ohana means family — and cake!</p>
  <p>&copy; 2025 <a href="https://www.instagram.com/liabakes_sg/" target="_blank" rel="noopener">LiaBakes SG</a>. Baked with love in Singapore.</p>
</footer>

<!-- THREE.JS SCENE -->
<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const loadingEl = document.getElementById('loading') as HTMLDivElement;

  // ═══ RENDERER ═══
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.4;

  // ═══ SCENE ═══
  const scene = new THREE.Scene();

  // ═══ CAMERA ═══
  const camera = new THREE.PerspectiveCamera(40, window.innerWidth / window.innerHeight, 0.1, 1000);
  camera.position.set(0, 2, 6);

  // ═══ CONTROLS ═══
  const controls = new OrbitControls(camera, canvas);
  controls.enableDamping = true;
  controls.dampingFactor = 0.05;
  controls.enableZoom = false;
  controls.enablePan = false;
  controls.autoRotate = false;
  controls.autoRotateSpeed = 1.5;
  controls.minPolarAngle = Math.PI * 0.3;
  controls.maxPolarAngle = Math.PI * 0.65;
  controls.target.set(0, 1, 0);

  // ═══ LIGHTS ═══
  const hemi = new THREE.HemisphereLight(0xffffff, 0xc8b6e2, 1.2);
  scene.add(hemi);

  const dirLight = new THREE.DirectionalLight(0xffffff, 1.8);
  dirLight.position.set(5, 10, 7);
  dirLight.castShadow = true;
  dirLight.shadow.mapSize.set(1024, 1024);
  dirLight.shadow.camera.near = 0.5;
  dirLight.shadow.camera.far = 50;
  dirLight.shadow.camera.left = -10;
  dirLight.shadow.camera.right = 10;
  dirLight.shadow.camera.top = 10;
  dirLight.shadow.camera.bottom = -10;
  scene.add(dirLight);

  const fillLight = new THREE.DirectionalLight(0xfdf6ec, 0.8);
  fillLight.position.set(-5, 5, -3);
  scene.add(fillLight);

  const backLight = new THREE.DirectionalLight(0xffffff, 0.6);
  backLight.position.set(0, 3, -8);
  scene.add(backLight);

  const pinkLight = new THREE.PointLight(0xf0a6ca, 0.6, 20);
  pinkLight.position.set(3, 4, 4);
  scene.add(pinkLight);

  const ambient = new THREE.AmbientLight(0xffffff, 0.5);
  scene.add(ambient);

  // ═══ SPARKLE PARTICLES ═══
  const particleCount = 100;
  const particleGeo = new THREE.BufferGeometry();
  const particlePositions = new Float32Array(particleCount * 3);
  for (let i = 0; i < particleCount; i++) {
    particlePositions[i * 3] = (Math.random() - 0.5) * 20;
    particlePositions[i * 3 + 1] = Math.random() * 10 - 2;
    particlePositions[i * 3 + 2] = (Math.random() - 0.5) * 20;
  }
  particleGeo.setAttribute('position', new THREE.BufferAttribute(particlePositions, 3));
  const particleMat = new THREE.PointsMaterial({
    color: 0xf0a6ca,
    size: 0.04,
    transparent: true,
    opacity: 0.5,
    blending: THREE.AdditiveBlending,
  });
  const particles = new THREE.Points(particleGeo, particleMat);
  scene.add(particles);

  // ═══ GROUND SHADOW DISC ═══
  const groundGeo = new THREE.CircleGeometry(4, 32);
  const groundMat = new THREE.ShadowMaterial({ opacity: 0.1 });
  const ground = new THREE.Mesh(groundGeo, groundMat);
  ground.rotation.x = -Math.PI / 2;
  ground.position.y = -0.01;
  ground.receiveShadow = true;
  scene.add(ground);

  // ═══ LOAD GLTF MODEL ═══
  const wrapper = new THREE.Group();
  scene.add(wrapper);
  let modelBaseY = 0;

  const loader = new GLTFLoader();
  loader.load(
    '/cupcake.glb',
    (gltf) => {
      const model = gltf.scene;
      wrapper.add(model);

      // Force all matrices so Box3 is accurate
      wrapper.updateMatrixWorld(true);

      // Get world-space bounding box of the model as-is
      const box = new THREE.Box3().setFromObject(model);
      const size = box.getSize(new THREE.Vector3());
      const center = box.getCenter(new THREE.Vector3());

      // Scale the wrapper to fit target size
      const maxDim = Math.max(size.x, size.y, size.z);
      const targetSize = 1.8;
      const sf = targetSize / maxDim;
      wrapper.scale.setScalar(sf);
      wrapper.updateMatrixWorld(true);

      // After scaling, recompute the box in world space
      const sBox = new THREE.Box3().setFromObject(model);
      const sCenter = sBox.getCenter(new THREE.Vector3());

      // Move the MODEL inside the wrapper so the center lands at wrapper origin
      // model.position is in wrapper-local space, so divide by scale
      model.position.x -= sCenter.x / sf;
      model.position.z -= sCenter.z / sf;
      // Lift so bottom sits at y=0 in world space
      model.position.y -= sBox.min.y / sf;

      wrapper.updateMatrixWorld(true);
      modelBaseY = 0;

      // Enable shadows
      model.traverse((child) => {
        if ((child as THREE.Mesh).isMesh) {
          child.castShadow = true;
          child.receiveShadow = true;
        }
      });

      // Recompute final box for camera framing
      const finalBox = new THREE.Box3().setFromObject(wrapper);
      const finalSize = finalBox.getSize(new THREE.Vector3());
      const lookAtY = finalSize.y * 0.45;
      controls.target.set(0, lookAtY, 0);
      camera.position.set(0, lookAtY, 6);
      controls.update();
      controls.autoRotate = true;

      loadingEl.classList.add('hidden');
    },
    undefined,
    (error) => {
      console.warn('Could not load cupcake.glb:', error);
      loadingEl.textContent = 'Place cupcake.glb in public/ folder';
    }
  );

  // ═══ RESIZE ═══
  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });

  // ═══ ANIMATE ═══
  const clock = new THREE.Clock();
  function animate() {
    requestAnimationFrame(animate);
    const t = clock.getElapsedTime();

    controls.update();

    // Gentle bob on the wrapper (oscillates around base, no drift)
    wrapper.position.y = modelBaseY + Math.sin(t * 1.2) * 0.03;

    // Sparkle drift upward
    const pos = particleGeo.attributes.position as THREE.BufferAttribute;
    for (let i = 0; i < particleCount; i++) {
      let y = pos.getY(i);
      y += 0.003;
      if (y > 8) y = -2;
      pos.setY(i, y);
    }
    pos.needsUpdate = true;
    particleMat.opacity = 0.3 + Math.sin(t * 2) * 0.15;

    renderer.render(scene, camera);
  }
  animate();

  // ═══ NAV + SCROLL ═══
  window.addEventListener('scroll', () => {
    document.getElementById('navbar')?.classList.toggle('scrolled', window.scrollY > 50);
  });

  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
  );
  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));
</script>

</Base>