---
import Base from '../layouts/Base.astro';
---
<Base title="LiaBakes SG — Home-baked treats with love 🧁">

<style is:global>
  /* ══════════════════════════════════════════
     TOKENS
     ══════════════════════════════════════════ */
  :root {
    --pink: #f0a6ca;
    --pink-hover: #e48bb5;
    --blue: #3b82c4;
    --navy: #1e3a5f;
    --sky: #7ec8e3;
    --cream: #fdf6ec;
    --warm: #8b6f47;
    --lilac: #c8b6e2;
    --rose: #fff5f9;
    --fd: 'Fredoka', sans-serif;
    --fb: 'Nunito', sans-serif;
    --ease: cubic-bezier(.4,0,.2,1);
    --bounce: cubic-bezier(.34,1.56,.64,1);
    --radius: 20px;
    --nav-h: 60px;
  }

  /* ══════════════════════════════════════════
     RESET
     ══════════════════════════════════════════ */
  *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
  body {
    font-family: var(--fb);
    background: var(--cream);
    color: var(--navy);
    overflow-x: hidden;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }
  a { text-decoration: none; color: inherit; }
  button { border: none; background: none; cursor: pointer; font: inherit; }

  /* ══════════════════════════════════════════
     NAV
     ══════════════════════════════════════════ */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    height: var(--nav-h);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 1.25rem;
    background: rgba(253,246,236,.88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1.5px solid rgba(126,200,227,.12);
    transition: box-shadow .3s var(--ease);
  }
  .nav.scrolled { box-shadow: 0 2px 20px rgba(30,58,95,.07); }
  .nav-logo {
    font-family: var(--fd); font-size: 1.5rem; font-weight: 700;
    color: var(--blue); z-index: 210;
  }
  .nav-logo span { color: var(--pink); }
  .nav-links {
    display: flex; gap: 2rem; list-style: none;
  }
  .nav-links a {
    font-weight: 600; font-size: .82rem;
    text-transform: uppercase; letter-spacing: 1.2px;
    color: var(--navy); transition: color .25s;
    padding: .5rem 0;
  }
  .nav-links a:hover { color: var(--blue); }

  /* Hamburger */
  .hamburger {
    display: none;
    width: 44px; height: 44px;
    align-items: center; justify-content: center;
    z-index: 210; -webkit-tap-highlight-color: transparent;
  }
  .hamburger-lines {
    width: 22px; height: 16px; position: relative;
  }
  .hamburger-lines span {
    display: block; width: 100%; height: 2px;
    background: var(--navy); border-radius: 2px;
    position: absolute; left: 0;
    transition: all .3s var(--ease);
  }
  .hamburger-lines span:nth-child(1) { top: 0; }
  .hamburger-lines span:nth-child(2) { top: 7px; }
  .hamburger-lines span:nth-child(3) { top: 14px; }
  .hamburger.open .hamburger-lines span:nth-child(1) { top: 7px; transform: rotate(45deg); }
  .hamburger.open .hamburger-lines span:nth-child(2) { opacity: 0; }
  .hamburger.open .hamburger-lines span:nth-child(3) { top: 7px; transform: rotate(-45deg); }

  /* Mobile overlay */
  .mobile-menu {
    position: fixed; inset: 0; z-index: 205;
    background: rgba(253,246,236,.97);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 2rem;
    opacity: 0; pointer-events: none;
    transition: opacity .3s var(--ease);
  }
  .mobile-menu.open { opacity: 1; pointer-events: auto; }
  .mobile-menu a {
    font-family: var(--fd); font-size: 1.6rem; font-weight: 600;
    color: var(--navy); padding: .75rem 2rem;
    -webkit-tap-highlight-color: transparent;
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
  }

  /* ══════════════════════════════════════════
     HERO
     ══════════════════════════════════════════ */
  .hero {
    position: relative;
    height: 100svh; min-height: 550px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    overflow: hidden;
    background: var(--cream);
  }
  .hero-canvas {
    position: absolute; inset: 0;
    width: 100% !important; height: 100% !important;
    touch-action: pan-y;
    cursor: grab;
  }
  .hero-canvas:active { cursor: grabbing; }

  .hero-content {
    position: relative; z-index: 2;
    text-align: center; pointer-events: none;
    padding: 0 1.25rem;
  }
  .hero-title {
    font-family: var(--fd);
    font-size: clamp(3rem, 10vw, 6.5rem);
    font-weight: 700; color: var(--navy);
    line-height: 1.05; margin-bottom: .3rem;
    text-shadow: 0 2px 30px rgba(253,246,236,.9);
  }
  .hero-title .accent { color: var(--pink); }
  .hero-sub {
    font-size: clamp(.95rem, 2.5vw, 1.2rem);
    font-weight: 500; color: var(--warm);
    margin-bottom: 1.8rem;
    text-shadow: 0 1px 10px rgba(253,246,236,.9);
  }
  .hero-cta {
    pointer-events: auto;
    display: inline-block;
    padding: .85rem 2.4rem;
    background: var(--pink); color: #fff;
    font-family: var(--fd); font-size: 1.05rem; font-weight: 600;
    border-radius: 50px;
    box-shadow: 0 4px 18px rgba(240,166,202,.35);
    transition: all .3s var(--ease);
    -webkit-tap-highlight-color: transparent;
  }
  .hero-cta:hover { background: var(--pink-hover); transform: translateY(-2px); box-shadow: 0 8px 25px rgba(240,166,202,.45); }
  .hero-cta:active { transform: scale(.97); }

  .hero-drag {
    position: absolute; bottom: 3.8rem; left: 50%; transform: translateX(-50%);
    z-index: 2; font-size: .65rem; font-weight: 600; color: var(--pink);
    text-transform: uppercase; letter-spacing: 1.5px;
    opacity: 0; animation: fadeIn 1s ease 3s forwards;
  }
  .hero-hint {
    position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
    z-index: 2; font-size: .7rem; font-weight: 600; color: var(--warm);
    text-transform: uppercase; letter-spacing: 2px;
    opacity: 0; animation: fadeIn 1s ease 2s forwards;
  }
  @keyframes fadeIn { to { opacity: .5; } }

  .hero-loader {
    position: absolute; inset: 0; z-index: 5;
    display: flex; align-items: center; justify-content: center;
    background: var(--cream);
    font-family: var(--fd); font-size: 1.1rem; color: var(--pink);
    transition: opacity .6s var(--ease);
  }
  .hero-loader.done { opacity: 0; pointer-events: none; }

  /* ══════════════════════════════════════════
     SECTIONS
     ══════════════════════════════════════════ */
  .section {
    padding: 5rem 1.25rem;
    max-width: 1000px; margin: 0 auto;
  }
  .section-title {
    font-family: var(--fd);
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 700; text-align: center;
    margin-bottom: .6rem;
  }
  .section-title .pink { color: var(--pink); }
  .section-title .blue { color: var(--blue); }
  .section-sub {
    text-align: center; font-size: 1.05rem;
    color: var(--warm); font-weight: 500;
    margin-bottom: 2.5rem;
    max-width: 500px; margin-left: auto; margin-right: auto;
  }

  /* ABOUT */
  .about-grid {
    display: grid; grid-template-columns: 1fr 1.2fr;
    gap: 3rem; align-items: center;
  }
  .about-img {
    aspect-ratio: 4/5; border-radius: var(--radius);
    background: linear-gradient(145deg, var(--sky), var(--lilac));
    display: flex; align-items: center; justify-content: center;
    font-size: 4rem; overflow: hidden;
    transition: transform .4s var(--ease);
  }
  .about-img:hover { transform: scale(1.02); }
  .about-text p { font-size: 1rem; line-height: 1.8; margin-bottom: 1rem; }
  .about-text .hl {
    background: linear-gradient(180deg, transparent 55%, rgba(240,166,202,.25) 55%);
    font-weight: 700;
  }
  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
    .about-img { aspect-ratio: 16/9; font-size: 3rem; }
  }

  /* MENU */
  .menu-section { background: var(--rose); }
  .menu-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem;
  }
  .menu-card {
    background: #fff; border-radius: var(--radius);
    padding: 1.75rem 1.5rem; text-align: center;
    border: 2px solid transparent;
    transition: all .35s var(--bounce);
    -webkit-tap-highlight-color: transparent;
  }
  .menu-card:hover, .menu-card:active {
    transform: translateY(-6px); border-color: var(--sky);
    box-shadow: 0 12px 32px rgba(59,130,196,.1);
  }
  .menu-emoji {
    font-size: 2.8rem; display: block; margin-bottom: .75rem;
    transition: transform .3s var(--bounce);
  }
  .menu-card:hover .menu-emoji,
  .menu-card:active .menu-emoji { transform: scale(1.2) rotate(-8deg); }
  .menu-card h3 { font-family: var(--fd); font-size: 1.15rem; margin-bottom: .35rem; }
  .menu-card p { font-size: .9rem; color: var(--warm); line-height: 1.55; }
  .menu-note {
    text-align: center; margin-top: 1.75rem;
    font-size: .85rem; color: var(--blue); font-weight: 600; font-style: italic;
  }
  @media (max-width: 520px) {
    .menu-grid { grid-template-columns: 1fr; }
  }

  /* ORDER */
  .order-section {
    background: var(--navy); padding: 5rem 1.25rem; text-align: center;
  }
  .order-section .section-title { color: #fff; }
  .order-section .section-sub { color: var(--sky); }
  .order-btns {
    display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .order-btn {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .9rem 2rem; border-radius: 50px;
    font-family: var(--fd); font-size: 1rem; font-weight: 600;
    color: #fff; transition: all .3s var(--ease);
    -webkit-tap-highlight-color: transparent;
  }
  .order-btn:active { transform: scale(.96); }
  .order-btn.ig {
    background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    box-shadow: 0 4px 15px rgba(220,39,67,.25);
  }
  .order-btn.wa { background: #25d366; box-shadow: 0 4px 15px rgba(37,211,102,.25); }
  .order-btn:hover { transform: translateY(-2px) scale(1.03); }
  @media (max-width: 520px) {
    .order-btns { flex-direction: column; align-items: center; }
    .order-btn { width: 100%; max-width: 280px; justify-content: center; }
  }

  /* FOOTER */
  footer {
    text-align: center; padding: 1.75rem 1.25rem;
    background: #172e4d; color: var(--sky); font-size: .82rem;
  }
  footer a { color: var(--pink); }
  .footer-tagline {
    font-family: var(--fd); font-size: .95rem;
    color: var(--lilac); margin-bottom: .3rem;
  }

  /* SCROLL REVEAL */
  .reveal {
    opacity: 0; transform: translateY(24px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .reveal:nth-child(2) { transition-delay: .08s; }
  .reveal:nth-child(3) { transition-delay: .16s; }
  .reveal:nth-child(4) { transition-delay: .24s; }
</style>

<!-- NAV -->
<nav class="nav" id="navbar">
  <a href="#hero" class="nav-logo">Lia<span>Bakes</span></a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#menu">Treats</a></li>
    <li><a href="#order">Order</a></li>
  </ul>
  <button class="hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
    <div class="hamburger-lines"><span></span><span></span><span></span></div>
  </button>
</nav>
<div class="mobile-menu" id="mobileMenu">
  <a href="#about">About</a>
  <a href="#menu">Treats</a>
  <a href="#order">Order</a>
</div>

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero-loader" id="heroLoader">Loading treats...</div>
  <canvas class="hero-canvas" id="heroCanvas"></canvas>
  <div class="hero-content">
    <h1 class="hero-title">Lia<span class="accent">Bakes</span></h1>
    <p class="hero-sub">Home-baked treats made with love in Singapore</p>
    <a href="#order" class="hero-cta">Order Now</a>
  </div>
  <div class="hero-drag">drag to spin</div>
  <div class="hero-hint">scroll down</div>
</section>

<!-- ABOUT -->
<section class="section" id="about">
  <h2 class="section-title reveal">Meet <span class="pink">Lia</span></h2>
  <p class="section-sub reveal">The baker behind the treats</p>
  <div class="about-grid">
    <div class="about-img reveal">👩‍🍳🧁✨</div>
    <div class="about-text">
      <p class="reveal">Hi! I'm <span class="hl">Lia</span>, a home baker based in sunny Singapore. What started as a hobby baking for family and friends has grown into something I absolutely love sharing with everyone.</p>
      <p class="reveal">Every treat is baked fresh with <span class="hl">quality ingredients</span> and a whole lot of heart. From classic cupcakes to custom celebration cakes, I pour my passion into every creation.</p>
      <p class="reveal">Whether it's a birthday, a gathering, or just a Tuesday that needs a little sweetness — I've got you covered!</p>
    </div>
  </div>
</section>

<!-- MENU -->
<section class="section menu-section" id="menu">
  <h2 class="section-title reveal">The <span class="blue">Treats</span></h2>
  <p class="section-sub reveal">Baked fresh, made to order</p>
  <div class="menu-grid">
    <div class="menu-card reveal">
      <span class="menu-emoji">🧁</span>
      <h3>Cupcakes</h3>
      <p>Classic flavours with beautiful buttercream swirls. Perfect for parties and gifting.</p>
    </div>
    <div class="menu-card reveal">
      <span class="menu-emoji">🎂</span>
      <h3>Custom Cakes</h3>
      <p>Celebration cakes tailored to your theme. Tell me your vision!</p>
    </div>
    <div class="menu-card reveal">
      <span class="menu-emoji">🍪</span>
      <h3>Cookies</h3>
      <p>Chunky, chewy cookies — chocolate chip, matcha, and red velvet.</p>
    </div>
    <div class="menu-card reveal">
      <span class="menu-emoji">🍰</span>
      <h3>Brownies &amp; Bars</h3>
      <p>Fudgy brownies and dessert bars — rich, indulgent, impossibly good.</p>
    </div>
  </div>
  <p class="menu-note reveal">Menu changes seasonally! Check Instagram for the latest bakes</p>
</section>

<!-- ORDER -->
<section class="order-section" id="order">
  <h2 class="section-title reveal">Ready to <span class="pink">Order</span>?</h2>
  <p class="section-sub reveal">DM me on Instagram or drop a WhatsApp message!</p>
  <div class="order-btns reveal">
    <a href="https://www.instagram.com/liabakes_sg/" target="_blank" rel="noopener" class="order-btn ig">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      @liabakes_sg
    </a>
    <a href="https://wa.me/" target="_blank" rel="noopener" class="order-btn wa">
